rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // For this app, we check if the user's role in their profile is 'admin'
      // or if they are the bootstrapped admin email
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'ogungbemidemilade72@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. Users collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.uid is string &&
               data.email is string &&
               data.role in ['user', 'admin'] &&
               data.subscriptionStatus in ['free', 'premium'];
      }

      allow create: if isSignedIn() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    (
                      // Regular user can only update savedRecipes
                      (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['savedRecipes'])) ||
                      // Admin can update anything
                      isAdmin()
                    );
    }

    // 2. Recipes collection
    match /recipes/{recipeId} {
      allow get: if true; // Publicly readable for browsing titles (previews)
      
      // List rules: enforce secure queries
      allow list: if true; 

      function isValidRecipe(data) {
        return data.title is string && data.title.size() < 200 &&
               data.instructions is list &&
               data.ingredients is list &&
               data.isPremium is bool &&
               data.tribe in ['Yoruba', 'Igbo', 'Hausa', 'General'];
      }

      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Transactions collection
    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());

      function isValidTransaction(data) {
        return data.userId == request.auth.uid &&
               data.amount is number &&
               data.status in ['pending', 'success', 'failed'] &&
               data.reference is string;
      }

      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      allow update: if isAdmin(); // Only system/admin can update status via backend
    }
  }
}
